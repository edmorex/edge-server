{
	# Email for Let's Encrypt registration/expiry notices.
	email {$ACME_EMAIL}
}

# ── Apex + www: static hello-world + example redirect ──────────────────────
edmorex.com, www.edmorex.com {
	encode zstd gzip

	# (1) Example redirect: /basecawheel -> external GitHub Pages app.
	#     `redir *` inside handle keeps it in the same ordered routing group.
	handle /basecawheel* {
		redir * https://edmorex.github.io/BasecaWheel/BasecaWheel.html
	}

	# ── Future STATIC web apps (edmorex.com/<name>) ───────────────────────
	# 1. Put the app's files in   sites/<name>/
	# 2. Add a block like this (handle_path strips the /<name> prefix):
	#
	#   handle_path /trivia* {
	#       root * /srv/sites/trivia
	#       file_server
	#   }

	# ── Future CONTAINERIZED apps (edmorex.com/<name>) ────────────────────
	# 1. Run the app as its own compose project joined to the `edge` network.
	# 2. Add a block like this (no prefix strip; app must handle the subpath,
	#    or serve it on a subdomain instead — see README):
	#
	#   handle /api* {
	#       reverse_proxy myapi:3000
	#   }

	# Default: the hello-world landing page. Keep this block LAST.
	handle {
		root * /srv/sites/root
		file_server
	}
}

# ── BasecaBot ──────────────────────────────────────────────────────────────
bot.edmorex.com {
	encode zstd gzip

	# Secure WebSocket hub: wss://bot.edmorex.com/ws?room=...&secret=...
	handle /ws* {
		reverse_proxy bot:8080
	}

	# Bot's bundled web apps (served from a mount of the bot repo's webapps/).
	handle_path /wheel*  { root * /srv/botapps/baseca-wheel; file_server }
	handle_path /sample* { root * /srv/botapps/sample-game;  file_server }
	handle_path /events* { root * /srv/botapps/event-sim;    file_server }

	handle { respond "BasecaBot is running." 200 }
}
